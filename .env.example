# ── Required ────────────────────────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=
MAX_BOT_TOKEN=

# ── Deployment ───────────────────────────────────────────────────────────────

REMOTE_HOST=
REMOTE_USER=root
REMOTE_PASSWORD=        # leave empty to use SSH key auth

# ── Optional – YouTube destination ───────────────────────────────────────────
#
# Required when any route has destination.network = "youtube".
# Create a project at console.cloud.google.com, enable YouTube Data API v3,
# set up OAuth 2.0 credentials (Desktop/Web), then complete the one-time
# authorization flow to obtain a refresh token. See docs/youtube.md.
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REFRESH_TOKEN=

# ── Optional – VK destination ─────────────────────────────────────────────────
#
# Required when any route has destination.network = "vk".
# Create a Standalone app at vk.com/dev, obtain an access token with
# wall, video, photos permissions. See docs/vk.md.
# VK_ACCESS_TOKEN=

# ── Optional – Facebook destination ─────────────────────────────────────────
#
# Required when any route has destination.network = "facebook".
# Get a Page Access Token from developers.facebook.com → your app → Graph API Explorer.
# The token must have pages_manage_posts and pages_read_engagement permissions.
# You can store the token here and reference it in routes.json via access_token_env,
# or paste it inline in routes.json as access_token (less secure).
# FB_PAGE_ACCESS_TOKEN=

# ── Optional – MTProto (large video > 20 MB support) ────────────────────────
#
# Get credentials at https://my.telegram.org/apps
# Without these, text / images / videos ≤ 20 MB still work normally.
# Videos > 20 MB will post as text with a warning instead of the attachment.

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# TELEGRAM_MTPROTO_SESSION_FILE=.mtproto_session

# ── Optional – advanced ──────────────────────────────────────────────────────

# TELEGRAM_API_BASE_URL=https://api.telegram.org
# ROUTING_CONFIG_PATH=config/routes.json
# DEFAULT_REPOST_DELAY_MS=3000
# DEFAULT_MEDIA_GROUP_COLLECT_MS=1200
# DEFAULT_INCLUDE_TELEGRAM_FOOTER=true

# ── Optional – API ingest endpoint ───────────────────────────────────────────
#
# When at least one route has source.network = "api" (or ADMIN_PASSWORD is
# set below), a lightweight HTTP server starts on this port. Each API route
# references an env var that holds its Bearer token (e.g. API_KEY_DEBUG).
# API_PORT=3000
# API_KEY_DEBUG=<random-secret-at-least-32-chars>

# ── Optional – Bridge admin CLI ──────────────────────────────────────────────
#
# Set ADMIN_PASSWORD to enable the /admin/* HTTP endpoints used by the
# `max-bot-bridge` CLI (see README → "Bridge CLI"). When empty, the admin
# API is fully disabled and all /admin/* paths return 404.
#
# ⚠️  The admin API speaks plaintext HTTP by default. Before exposing it to
#     the internet, tunnel over SSH or put it behind TLS (Caddy/Nginx).
# ADMIN_PASSWORD=<a-long-random-secret>

# Backup retention and mode. These are *defaults* — the CLI can override
# them at runtime via `max-bot-bridge settings set backups.keep 30`, and
# the override is stored in config/settings.json. If these env vars are
# set, they take precedence over the settings file on every reload
# (useful if you want to hard-lock the policy).
#
#   BACKUPS_KEEP=20                # integer 1..1000; how many snapshots to keep
#   BACKUPS_MODE=auto              # auto | manual (auto = snapshot before every change)

# ── Optional – temp-file overflow protection ─────────────────────────────────
#
# Minimum free disk space (MB) required in os.tmpdir() before downloading
# a media file. If free space is below this threshold the download is
# rejected with an error instead of filling up the disk.
# Requires Node.js ≥ 19.6 (fs.statfsSync); silently skipped on older versions.
# TEMP_MIN_FREE_MB=1000
